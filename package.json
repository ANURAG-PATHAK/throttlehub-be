{
  "name": "throttlehub-be",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/server.ts",
    "start": "node --env-file=.env dist/server.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\" \"scripts/**/*.ts\" && prettier -c \"**/*.{ts,js,json,md,yml,yaml}\"",
    "format": "eslint \"src/**/*.ts\" \"scripts/**/*.ts\" --fix && prettier --write \"**/*.{ts,js,json,md,yml,yaml}\"",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "openapi:generate": "tsx scripts/generate-openapi.ts",
    "openapi:check": "pnpm openapi:generate && git diff --exit-code docs/api/openapi.yaml"
  },
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "@fastify/env": "^5.0.3",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/sensible": "^6.0.3",
    "@fastify/swagger": "^9.5.2",
    "@fastify/swagger-ui": "^5.2.3",
    "@fastify/type-provider-typebox": "^6.1.0",
    "@prisma/adapter-pg": "^7.4.0",
    "@prisma/client": "^7.4.0",
    "@sinclair/typebox": "^0.34.41",
    "argon2": "^0.44.0",
    "dotenv": "^17.3.1",
    "fastify": "^5.6.1",
    "fastify-plugin": "^5.1.0",
    "nodemailer": "^8.0.1",
    "pg": "^8.18.0",
    "pino": "^10.3.1",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.4.0",
    "@types/nodemailer": "^7.0.10",
    "@types/pg": "^8.16.0",
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@typescript-eslint/parser": "^8.46.2",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.6.2",
    "prisma": "^7.4.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.2"
  },
  "engines": {
    "node": ">=20"
  }
}
